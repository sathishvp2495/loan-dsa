generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
  OPERATIONS
}

enum LoanType {
  PERSONAL
  HOME
  BUSINESS
  MORTGAGE
  CAR
  EDUCATION
  GOLD
}

enum EmploymentType {
  SALARIED
  SELF_EMPLOYED
  BUSINESS_OWNER
  OTHER
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  GOOGLE
  REFERRAL
  MANUAL
}

enum LeadStage {
  NEW_LEAD
  CONTACT_ATTEMPTED
  CONTACTED
  QUALIFIED
  DOCS_PENDING
  BANK_SUBMITTED
  SANCTIONED
  DISBURSED
  REJECTED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
}

model User {
  id            String              @id @default(uuid())
  fullName      String
  email         String              @unique
  passwordHash  String
  role          UserRole            @default(AGENT)
  isActive      Boolean             @default(true)
  assignedLeads Lead[]              @relation("LeadAssignedAgent")
  notes         LeadNote[]
  stageChanges  LeadStatusHistory[] @relation("LeadStageChangedBy")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Lead {
  id              String              @id @default(uuid())
  referenceCode   String              @unique @default(cuid())
  fullName        String
  phone           String
  whatsappPhone   String?
  city            String
  loanType        LoanType
  employmentType  EmploymentType
  monthlyIncome   Int
  requestedAmount Int
  source          LeadSource          @default(WEBSITE)
  stage           LeadStage           @default(NEW_LEAD)
  whatsappOptIn   Boolean             @default(false)
  assignedAgentId String?
  assignedAgent   User?               @relation("LeadAssignedAgent", fields: [assignedAgentId], references: [id])
  lastContactedAt DateTime?
  notes           LeadNote[]
  statusHistory   LeadStatusHistory[]
  commission      Commission?
  messages        CustomerMessage[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([stage])
  @@index([phone])
  @@index([whatsappPhone])
  @@index([assignedAgentId])
}

model LeadNote {
  id              String   @id @default(uuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  body            String
  systemGenerated Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([leadId])
}

model LeadStatusHistory {
  id            String    @id @default(uuid())
  leadId        String
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  previousStage LeadStage?
  nextStage     LeadStage
  changedById   String?
  changedBy     User?     @relation("LeadStageChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  reason        String?
  createdAt     DateTime  @default(now())

  @@index([leadId])
}

model Commission {
  id                 String   @id @default(uuid())
  leadId             String   @unique
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lenderName         String
  disbursedAmount    Int
  payoutPercent      Decimal  @db.Decimal(6, 2)
  totalCommission    Decimal  @db.Decimal(12, 2)
  partnerSharePercent Decimal @db.Decimal(6, 2)
  partnerShareAmount Decimal  @db.Decimal(12, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CustomerMessage {
  id                String           @id @default(uuid())
  leadId            String?
  lead              Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  direction         MessageDirection
  channel           MessageChannel   @default(WHATSAPP)
  providerMessageId String?
  templateName      String?
  body              String?
  status            String?
  fromIdentity      String?
  toIdentity        String?
  payload           Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([leadId])
}
